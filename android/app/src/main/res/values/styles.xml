<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window as soon as the process has started.
         This theme determines the app's initial visual appearance, and is
         active until the first frame of Flutter itself is rendered. -->
    <style name="LaunchTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Show a splash screen on the activity. Automatically removed when
             the Flutter engine draws its first frame -->
        <item android:windowBackground="@drawable/launch_background" />
    </style>

    <!-- Theme applied to the Android Window as soon as the Flutter experience
         begins. This theme inherits the LaunchTheme but overrides the window
         background to prevent caching of the splash screen. -->
    <style name="NormalTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item android:windowBackground="?android:colorBackground" />
    </style>
</resources>
