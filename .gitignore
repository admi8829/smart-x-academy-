# -------------------------------------------------------------
# Smart X Academy - Git Configuration
# -------------------------------------------------------------
# This file is optimized to ensure ONLY clean Flutter code is 
# tracked and pushed to GitHub. All auxiliary playground web assets 
# (React, TSX, Vite, CSS, layout simulator components) are ignored.

# Ignore Flutter/Dart output and caches
build/
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
__pycache__/
*.lock

# Ignore IDE configs
.idea/
.vscode/
*.cert
*.keystore

# Ignore OS files
.DS_Store
Thumbs.db

# -------------------------------------------------------------
# STRICTLY IGNORE LOCAL WEB EMULATOR & PLAYGROUND WEB CORE
# Ensure only the Flutter codebase is pushed to your GitHub Repository!
# All auxiliary playground web assets, Vite dev server configs, 
# tailwind/postcss configurations, and local emulators are ignored.
# -------------------------------------------------------------
node_modules/
dist/
src/
public/
index.html
server.js
vite.config.ts
vite.config.js
tsconfig.json
tsconfig.node.json
tsconfig.app.json
package.json
package-lock.json
metadata.json
components.json
tailwind.config.js
tailwind.config.ts
tailwind.config.cjs
postcss.config.js
postcss.config.cjs
eslint.config.js
eslint.config.mjs
eslint.config.cjs
.env*
!.env.example
*.log
.firebase/
firebase-blueprint.json
