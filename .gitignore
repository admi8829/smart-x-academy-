# -------------------------------------------------------------
# Smart X Academy - Git Configuration
# -------------------------------------------------------------
# This file is optimized to ensure ONLY clean Flutter code is 
# tracked and pushed to GitHub. All auxiliary playground web assets 
# (React, TSX, Vite, CSS, layout simulator components) are ignored.

# Ignore Flutter/Dart output and caches
build/
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
__pycache__/
*.lock

# Ignore IDE configs
.idea/
.vscode/
*.cert
*.keystore

# Ignore OS files
.DS_Store
Thumbs.db

# -------------------------------------------------------------
# STRICTLY IGNORE PLAYGROUND WEB CORE (Frontend Simulator Helper)
# Ensure only the Flutter codebase is pushed to your GitHub Repository!
# -------------------------------------------------------------
node_modules/
dist/
/src/
index.html
vite.config.ts
tsconfig.json
package.json
package-lock.json
metadata.json
components.json
.env*
!.env.example
*.log

# Prevent ignoring AndroidManifest.xml
!/android/app/src/main/AndroidManifest.xml
